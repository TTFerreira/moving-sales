---
import Layout from '../../layouts/Layout.astro';
import ItemCard from '../../components/ItemCard.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('items');

// Sort all items by date descending (default) at build time
const sortedItems = [...allItems].sort((a, b) =>
  b.data.dateAdded.localeCompare(a.data.dateAdded)
);

const categories = [...new Set(allItems.map(i => i.data.category))].sort();
const statuses = ['available', 'reserved', 'sold'] as const;
---

<Layout title="All Items">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
      <h1 id="page-title" class="text-3xl font-bold text-gray-900">All Items</h1>
      <p id="item-count" class="text-gray-500 mt-1">{sortedItems.length} items found</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Sidebar filters -->
      <aside class="lg:w-64 flex-shrink-0">
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 sticky top-20">
          <h2 class="font-semibold text-gray-800 mb-4">Filter Items</h2>

          <div class="space-y-4">
            <div>
              <p class="text-sm font-medium text-gray-600 mb-2">Category</p>
              <div class="flex flex-wrap gap-2">
                <button
                  data-filter-category=""
                  class="filter-cat-btn px-3 py-1.5 rounded-full text-sm font-medium transition-colors bg-amber-500 text-white"
                >
                  🏷️ All
                </button>
                {categories.map(cat => (
                  <button
                    data-filter-category={cat}
                    class="filter-cat-btn px-3 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-200 hover:border-amber-400 hover:text-amber-600"
                  >
                    {cat.charAt(0).toUpperCase() + cat.slice(1)}
                  </button>
                ))}
              </div>
            </div>

            <div>
              <p class="text-sm font-medium text-gray-600 mb-2">Status</p>
              <div class="flex flex-wrap gap-2">
                <button
                  data-filter-status=""
                  class="filter-status-btn px-3 py-1.5 rounded-full text-sm font-medium transition-colors bg-gray-800 text-white"
                >
                  All
                </button>
                {statuses.map(s => (
                  <button
                    data-filter-status={s}
                    class="filter-status-btn px-3 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-200 hover:border-gray-400"
                  >
                    {s.charAt(0).toUpperCase() + s.slice(1)}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <div class="mt-6 pt-4 border-t border-gray-100">
            <p class="text-sm font-medium text-gray-600 mb-2">Sort By</p>
            <div class="space-y-1">
              {[
                { value: 'date-desc', label: 'Newest First' },
                { value: 'date-asc', label: 'Oldest First' },
                { value: 'price-asc', label: 'Price: Low to High' },
                { value: 'price-desc', label: 'Price: High to Low' },
              ].map(opt => (
                <button
                  data-sort={opt.value}
                  class={`sort-btn block w-full text-left px-3 py-1.5 rounded text-sm transition-colors ${opt.value === 'date-desc' ? 'bg-amber-50 text-amber-700 font-medium' : 'text-gray-600 hover:bg-gray-50'}`}
                >
                  {opt.label}
                </button>
              ))}
            </div>
          </div>
        </div>
      </aside>

      <!-- Items grid -->
      <div class="flex-1">
        <div id="empty-state" class="hidden text-center py-16 text-gray-500">
          <div class="text-5xl mb-4">🔍</div>
          <p class="text-xl font-medium">No items found</p>
          <p class="mt-2">Try adjusting your filters</p>
        </div>
        <div id="items-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
          {sortedItems.map(item => (
            <div
              class="item-wrapper"
              data-category={item.data.category}
              data-status={item.data.status}
              data-price={item.data.askingPrice}
              data-date={item.data.dateAdded}
            >
              <ItemCard
                slug={item.id}
                title={item.data.title}
                category={item.data.category}
                condition={item.data.condition}
                askingPrice={item.data.askingPrice}
                originalPrice={item.data.originalPrice}
                status={item.data.status}
                images={item.data.images}
                featured={item.data.featured}
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const grid = document.getElementById('items-grid');
  const emptyState = document.getElementById('empty-state');
  const countEl = document.getElementById('item-count');
  const titleEl = document.getElementById('page-title');

  let activeCategory = '';
  let activeStatus = '';
  let activeSort = 'date-desc';

  function syncFromUrl() {
    const params = new URLSearchParams(window.location.search);
    activeCategory = params.get('category') || '';
    activeStatus = params.get('status') || '';
    activeSort = params.get('sort') || 'date-desc';
  }

  function updateUrl() {
    const params = new URLSearchParams();
    if (activeCategory) params.set('category', activeCategory);
    if (activeStatus) params.set('status', activeStatus);
    if (activeSort && activeSort !== 'date-desc') params.set('sort', activeSort);
    const qs = params.toString();
    history.replaceState(null, '', '/items' + (qs ? '?' + qs : ''));
  }

  function applyFilters() {
    if (!grid) return;
    const wrappers = Array.from(grid.querySelectorAll<HTMLElement>('.item-wrapper'));

    // Filter
    const visible = wrappers.filter(w => {
      const cat = w.dataset.category || '';
      const st = w.dataset.status || '';
      return (!activeCategory || cat === activeCategory) && (!activeStatus || st === activeStatus);
    });
    const hidden = wrappers.filter(w => !visible.includes(w));

    visible.forEach(w => { w.style.display = ''; });
    hidden.forEach(w => { w.style.display = 'none'; });

    // Sort visible items
    visible.sort((a, b) => {
      switch (activeSort) {
        case 'price-asc': return Number(a.dataset.price) - Number(b.dataset.price);
        case 'price-desc': return Number(b.dataset.price) - Number(a.dataset.price);
        case 'date-asc': return (a.dataset.date || '').localeCompare(b.dataset.date || '');
        default: return (b.dataset.date || '').localeCompare(a.dataset.date || '');
      }
    });
    visible.forEach(w => grid.appendChild(w));

    // Update count & title
    const count = visible.length;
    if (countEl) countEl.textContent = `${count} item${count !== 1 ? 's' : ''} found`;
    if (titleEl) {
      titleEl.textContent = activeCategory
        ? `${activeCategory.charAt(0).toUpperCase() + activeCategory.slice(1)} Items`
        : activeStatus
        ? `${activeStatus.charAt(0).toUpperCase() + activeStatus.slice(1)} Items`
        : 'All Items';
    }
    if (emptyState) emptyState.classList.toggle('hidden', count > 0);

    // Update button active states
    document.querySelectorAll<HTMLElement>('.filter-cat-btn').forEach(btn => {
      const isActive = (btn.dataset.filterCategory ?? '') === activeCategory;
      btn.className = `filter-cat-btn px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${
        isActive ? 'bg-amber-500 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-amber-400 hover:text-amber-600'
      }`;
    });
    document.querySelectorAll<HTMLElement>('.filter-status-btn').forEach(btn => {
      const isActive = (btn.dataset.filterStatus ?? '') === activeStatus;
      btn.className = `filter-status-btn px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${
        isActive ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-gray-400'
      }`;
    });
    document.querySelectorAll<HTMLElement>('.sort-btn').forEach(btn => {
      const isActive = (btn.dataset.sort ?? '') === activeSort;
      btn.className = `sort-btn block w-full text-left px-3 py-1.5 rounded text-sm transition-colors ${
        isActive ? 'bg-amber-50 text-amber-700 font-medium' : 'text-gray-600 hover:bg-gray-50'
      }`;
    });
  }

  // Wire up filter buttons
  document.querySelectorAll<HTMLElement>('.filter-cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.filterCategory || '';
      updateUrl();
      applyFilters();
    });
  });
  document.querySelectorAll<HTMLElement>('.filter-status-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.filterStatus || '';
      updateUrl();
      applyFilters();
    });
  });
  document.querySelectorAll<HTMLElement>('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeSort = btn.dataset.sort || 'date-desc';
      updateUrl();
      applyFilters();
    });
  });

  // Apply on load (handles direct URL with query params)
  syncFromUrl();
  applyFilters();
</script>
