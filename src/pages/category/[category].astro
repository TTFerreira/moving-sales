---
import Layout from '../../layouts/Layout.astro';
import ItemCard from '../../components/ItemCard.astro';
import { getCollection } from 'astro:content';
import { base } from '../../utils/base';

export async function getStaticPaths() {
  const items = await getCollection('items');
  const categories = [...new Set(items.map(i => i.data.category))];
  return categories.map(category => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props;
const allItems = await getCollection('items');
const items = allItems.filter(item => item.data.category === category);

const availableCount = items.filter(i => i.data.status === 'available').length;

const categoryLabels: Record<string, string> = {
  furniture: 'Furniture',
  electronics: 'Electronics',
  kitchen: 'Kitchen & Appliances',
  outdoor: 'Outdoor & Garden',
  clothing: 'Clothing & Fashion',
  books: 'Books',
  toys: 'Toys & Games',
  sports: 'Sports & Fitness',
  tools: 'Tools & DIY',
  decor: 'Home Decor',
  misc: 'Miscellaneous',
};

const categoryIcons: Record<string, string> = {
  furniture: '🛋️',
  electronics: '📺',
  kitchen: '🍳',
  outdoor: '🌿',
  clothing: '👕',
  books: '📚',
  toys: '🧸',
  sports: '⚽',
  tools: '🔧',
  decor: '🏺',
  misc: '📦',
};

const label = categoryLabels[category] || category;
const icon = categoryIcons[category] || '📦';
---

<Layout title={label}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-100 rounded-2xl p-6 mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-4xl">{icon}</span>
        <h1 class="text-3xl font-bold text-gray-900">{label}</h1>
      </div>
      <p class="text-gray-600">
        {items.length} item{items.length !== 1 ? 's' : ''} total ·
        <span class="text-green-600 font-medium">{availableCount} available</span>
      </p>
      <div class="mt-3 flex gap-3">
        <a href={`${base}items`} class="text-sm text-amber-600 hover:underline">← All Items</a>
        <a href={`${base}items?category=${category}&status=available`} class="text-sm bg-amber-500 text-white px-3 py-1 rounded-full hover:bg-amber-600 transition-colors">
          Show Available Only
        </a>
      </div>
    </div>

    {items.length === 0 ? (
      <div class="text-center py-16 text-gray-500">
        <div class="text-5xl mb-4">{icon}</div>
        <p class="text-xl">No items in this category</p>
        <a href={`${base}items`} class="mt-4 inline-block text-amber-600 hover:underline">Browse all items</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {items.map(item => (
          <ItemCard
            slug={item.id}
            title={item.data.title}
            category={item.data.category}
            condition={item.data.condition}
            askingPrice={item.data.askingPrice}
            originalPrice={item.data.originalPrice}
            status={item.data.status}
            images={item.data.images}
            featured={item.data.featured}
          />
        ))}
      </div>
    )}
  </div>
</Layout>
