---
interface Props {
  condition: 'new' | 'like-new' | 'good' | 'fair' | 'poor';
}

const { condition } = Astro.props;

const config = {
  'new': { label: 'New', class: 'bg-emerald-100 text-emerald-800' },
  'like-new': { label: 'Like New', class: 'bg-teal-100 text-teal-800' },
  'good': { label: 'Good', class: 'bg-blue-100 text-blue-800' },
  'fair': { label: 'Fair', class: 'bg-yellow-100 text-yellow-800' },
  'poor': { label: 'Poor', class: 'bg-gray-100 text-gray-600' },
};

const badge = config[condition];
---

<span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${badge.class}`}>
  {badge.label}
</span>
