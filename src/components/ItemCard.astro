---
import StatusBadge from './StatusBadge.astro';
import ConditionBadge from './ConditionBadge.astro';
import PriceDisplay from './PriceDisplay.astro';
import { base } from '../utils/base';

interface Props {
  slug: string;
  title: string;
  category: string;
  condition: 'new' | 'like-new' | 'good' | 'fair' | 'poor';
  askingPrice: number;
  originalPrice?: number;
  status: 'available' | 'reserved' | 'sold';
  images: string[];
  featured?: boolean;
  tags?: string[];
}

const { slug, title, category, condition, askingPrice, originalPrice, status, images, featured } = Astro.props;

const categoryIcons: Record<string, string> = {
  furniture: '🛋️',
  electronics: '📺',
  kitchen: '🍳',
  outdoor: '🌿',
  clothing: '👕',
  books: '📚',
  toys: '🧸',
  sports: '⚽',
  tools: '🔧',
  decor: '🏺',
  misc: '📦',
};

const hasImage = images && images.length > 0;
---

<article class={`bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden border border-gray-100 hover:border-amber-200 group ${status === 'sold' ? 'opacity-75' : ''}`}>
  <a href={`${base}items/${slug}`} class="block">
    <div class="relative aspect-[4/3] bg-gradient-to-br from-amber-50 to-orange-100 overflow-hidden">
      {hasImage ? (
        <img
          src={images[0]}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="hidden w-full h-full items-center justify-center text-6xl absolute inset-0 bg-gradient-to-br from-amber-50 to-orange-100">
          {categoryIcons[category] || '📦'}
        </div>
      ) : (
        <div class="w-full h-full flex items-center justify-center text-6xl">
          {categoryIcons[category] || '📦'}
        </div>
      )}
      {featured && (
        <div class="absolute top-2 left-2 bg-amber-500 text-white text-xs font-bold px-2 py-1 rounded-full">
          ⭐ Featured
        </div>
      )}
      <div class="absolute top-2 right-2">
        <StatusBadge status={status} />
      </div>
    </div>
    <div class="p-4">
      <div class="flex items-start justify-between gap-2 mb-1">
        <h3 class="font-semibold text-gray-900 group-hover:text-amber-700 transition-colors line-clamp-2 text-sm leading-snug">
          {title}
        </h3>
      </div>
      <div class="flex items-center gap-2 mb-2 flex-wrap">
        <span class="text-xs text-gray-500 capitalize">{categoryIcons[category]} {category}</span>
        <ConditionBadge condition={condition} />
      </div>
      <PriceDisplay askingPrice={askingPrice} originalPrice={originalPrice} />
    </div>
  </a>
</article>
