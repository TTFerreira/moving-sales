---
interface Props {
  askingPrice: number;
  originalPrice?: number;
  large?: boolean;
}

const { askingPrice, originalPrice, large = false } = Astro.props;

const savings = originalPrice ? originalPrice - askingPrice : null;
const savingsPct = originalPrice ? Math.round((savings! / originalPrice) * 100) : null;
---

<div class={`flex flex-wrap items-baseline gap-2 ${large ? 'gap-3' : ''}`}>
  <span class={`font-bold text-amber-700 ${large ? 'text-3xl' : 'text-lg'}`}>
    ${askingPrice.toLocaleString()}
  </span>
  {originalPrice && (
    <span class={`text-gray-400 line-through ${large ? 'text-lg' : 'text-sm'}`}>
      ${originalPrice.toLocaleString()}
    </span>
  )}
  {savingsPct && savingsPct > 0 && (
    <span class={`bg-green-100 text-green-700 font-semibold rounded px-1.5 py-0.5 ${large ? 'text-sm' : 'text-xs'}`}>
      Save {savingsPct}%
    </span>
  )}
</div>
