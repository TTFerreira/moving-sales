{
  "$ref": "#/definitions/items",
  "definitions": {
    "items": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "furniture",
            "electronics",
            "kitchen",
            "outdoor",
            "clothing",
            "books",
            "toys",
            "sports",
            "tools",
            "decor",
            "misc"
          ]
        },
        "condition": {
          "type": "string",
          "enum": [
            "new",
            "like-new",
            "good",
            "fair",
            "poor"
          ]
        },
        "askingPrice": {
          "type": "number"
        },
        "originalPrice": {
          "type": "number"
        },
        "specs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "youtubeVideoId": {
          "type": "string"
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "url"
            ],
            "additionalProperties": false
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "available",
            "reserved",
            "sold"
          ],
          "default": "available"
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "dateAdded": {
          "type": "string",
          "default": "2026-04-25"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "category",
        "condition",
        "askingPrice"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}